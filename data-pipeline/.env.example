# Reddit OAuth credentials for the real scraper (npm run scrape:reddit:real).
# Reddit 403s unauthenticated requests now, so this is required to get data.
#
# How to get these (2 minutes, free):
#   1. Go to https://www.reddit.com/prefs/apps  (log in with any Reddit account)
#   2. Click "create another app..." at the bottom
#   3. Choose type: "script"
#        name:         compass-research
#        redirect uri: http://localhost:8080   (required field, not actually used)
#   4. Create it. Then:
#        - CLIENT_ID  = the string shown UNDER the app name (top-left, ~14 chars)
#        - SECRET     = the "secret" field
#   5. Copy this file to  data-pipeline/.env  and fill the values below.
#   6. Run:  npm run scrape:reddit:real
#
# Note: a "script" app authenticates as YOUR Reddit account (username+password).
# Use a throwaway account if you prefer. Keep .env out of git.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=compass-research/1.0 by u/your_username
